# Lumina Configuration Template
# Copy this file to .env and fill in your API keys

# ===== LLM Provider Settings =====
# Options: openai, anthropic, google, groq
LUMINA_PROVIDER=openai

# Model to use (depends on provider)
# OpenAI: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
LUMINA_MODEL=gpt-4-turbo-preview

# ===== API Keys =====
# Get your keys from:
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/settings/keys
# Google: https://makersuite.google.com/app/apikey

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
GROQ_API_KEY=...

# ===== Agent Settings =====
# Maximum iterations per task
LUMINA_MAX_ITERATIONS=10

# Temperature for generation (0.0-2.0, higher = more creative)
LUMINA_TEMPERATURE=0.7

# Maximum tokens per response
LUMINA_MAX_TOKENS=4000

# Enable verbose logging
LUMINA_VERBOSE=true

# Enable debug mode (very detailed logs)
LUMINA_DEBUG=false

# ===== Memory Settings =====
# Enable memory system
LUMINA_ENABLE_MEMORY=true

# Memory retention in days
LUMINA_MEMORY_RETENTION_DAYS=30

# ===== Security Settings =====
# Allow code execution tools
LUMINA_ALLOW_CODE_EXEC=true

# Sandbox code execution
LUMINA_SANDBOX_CODE=true

# Maximum file size in MB
LUMINA_MAX_FILE_SIZE_MB=10
